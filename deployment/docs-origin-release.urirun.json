{
  "id": "docs-origin-release",
  "name": "docs.subactor.com origin release (uploadâ†’verifyâ†’activate)",
  "description": "Formal PR7 release to subdomain docroot /docs.subactor.com. Does NOT flip public DNS (PR9 HITL). Apply requires AUTONOMY_MUTATIONS_ENABLED=1, PLESK_SYNC_APPLY=1, plan_hash, and signed apply_grant. Origin verify via --resolve 217.160.250.222.",
  "situation": {
    "source_dir": "/home/tom/github/subactor/docs",
    "host": "prototypowanie.pl",
    "domain": "docs.subactor.com",
    "release_root": "/docs.subactor.com",
    "origin_ip": "217.160.250.222",
    "staging_domain": "docs-stage.subactor.com"
  },
  "uri_processes": [
    {
      "id": "docs-subdomain-ensure",
      "name": "Ensure docs subdomain exists under subactor.com",
      "actor": "bot:project-operator-bot",
      "uri": "plesk://host/site/command/subdomain-ensure",
      "payload": {
        "parent_domain": "subactor.com",
        "subdomain": "docs",
        "www_root": "docs.subactor.com",
        "base_url": "https://prototypowanie.pl:8443"
      },
      "depends_on": [],
      "human_approval": false
    },
    {
      "id": "docs-methods",
      "name": "Detect SFTP/FTP",
      "actor": "bot:project-operator-bot",
      "uri": "plesk://host/site/query/methods",
      "payload": {"host": "prototypowanie.pl"},
      "depends_on": ["docs-subdomain-ensure"],
      "human_approval": false
    },
    {
      "id": "docs-release-upload-dry",
      "name": "Dry-run release-upload under /docs.subactor.com/releases/",
      "actor": "bot:project-operator-bot",
      "uri": "plesk://host/site/command/release-upload",
      "payload": {
        "source_dir": "/home/tom/github/subactor/docs",
        "release_root": "/docs.subactor.com",
        "host": "prototypowanie.pl",
        "domain": "docs.subactor.com",
        "apply": false,
        "transport": "sftp",
        "exclude": [
          "Dockerfile",
          "docker-compose.yml",
          ".gitignore",
          "koru.yaml",
          "deployment",
          "deployment/*",
          "CNAME"
        ]
      },
      "depends_on": ["docs-methods"],
      "human_approval": false
    }
  ]
}
